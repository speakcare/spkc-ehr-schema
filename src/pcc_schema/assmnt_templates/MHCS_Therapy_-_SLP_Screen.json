          "questions": [
            {
              "questionKey": "Cust_02_4a",
              "questionNumber": "4a",
              "questionText": "<i>Examples include but not limited to:  Complaints of food getting stuck or swallowing pain; Complaints of excessive time to eat/poor activity tolerance; Complaints of swallow difficulty due to dental/denture issue; Complaints of discomfort or esophageal symptoms ",
              "questionTitle": "",
              "questionType": "inst",
              "required": false,
              "length": 50,
              "range": "",
              "responseOptions": []
            },
            {
              "questionKey": "Cust_02_3a",
              "questionNumber": "3a",
              "questionText": "<i>Examples include but not limited to:  Coughing, gagging, or choking during/after swallow; Turning red or changing color during/after swallow; Labored breathing/difficulty speaking during/after swallow.",
              "questionTitle": "",
              "questionType": "inst",
              "required": false,
              "length": 50,
              "range": "",
              "responseOptions": []
            },
            {
              "questionKey": "Cust_02_2a",
              "questionNumber": "2a",
              "questionText": "<i>Examples include but not limited to:  Food/liquid residue on/around tongue, cheek, gums; Stops chewing and holds food/fluids in mouth for prolonged time; Requires oral care to remove food/liquid from mouth after eating</i>",
              "questionTitle": "",
              "questionType": "inst",
              "required": false,
              "length": 50,
              "range": "",
              "responseOptions": []
            },
            {
              "questionKey": "Cust_02_1a",
              "questionNumber": "1a",
              "questionText": "<i>Examples include but not limited to:  Food/liquid spilling from lips; Food/liquid residue on lips/cheeks/chin from spillage; Drooling food/liquids when eating</i>",
